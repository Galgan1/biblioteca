# Normaliza line endings: armazena LF no git, mantém LF no disco
# Elimina o ruído de CRLF×LF no Windows com core.autocrlf=true
* text=auto eol=lf

# Forçar LF explicitamente nos tipos que o pipeline gera
*.html text eol=lf
*.js   text eol=lf
*.css  text eol=lf
*.json text eol=lf
*.py   text eol=lf
*.md   text eol=lf
*.txt  text eol=lf
*.xml  text eol=lf

# Binários — sem conversão
*.mp4  binary
*.mp3  binary
*.wav  binary
*.png  binary
*.jpg  binary
*.gif  binary
*.ico  binary
*.sf2  binary
*.7z   binary
*.db   binary
